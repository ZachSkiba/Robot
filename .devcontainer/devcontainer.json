{
  "name": "6-DOF Robot Arm (Production)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "USERNAME": "devuser",
      "USER_UID": "1000",
      "USER_GID": "1000"
    }
  },
  "remoteUser": "devuser",
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=${localWorkspaceFolder}/..,target=/workspace,type=bind,consistency=cached",
    "source=robot-bashhistory,target=/home/devuser/commandhistory,type=volume",
    "source=robot-build,target=/workspace/build,type=volume",
    "source=robot-install,target=/workspace/install,type=volume",
    "source=robot-log,target=/workspace/log,type=volume"
  ],
  "containerEnv": {
    "ROS_DISTRO": "humble",
    "ROS_WS": "/workspace",
    "PROMPT_COMMAND": "history -a",
    "HISTFILE": "/home/devuser/commandhistory/.bash_history"
  },
  "runArgs": [
    "--network=host",
    "--ipc=host",
    "--privileged",
    "--pid=host",
    "--device=/dev/dri:/dev/dri",
    "--device=/dev/bus/usb:/dev/bus/usb",
    "-e",
    "DISPLAY=${localEnv:DISPLAY}",
    "-e",
    "WAYLAND_DISPLAY=${localEnv:WAYLAND_DISPLAY}",
    "-e",
    "XDG_RUNTIME_DIR=${localEnv:XDG_RUNTIME_DIR}",
    "-e",
    "PULSE_SERVER=${localEnv:PULSE_SERVER}",
    "-v",
    "/tmp/.X11-unix:/tmp/.X11-unix",
    "-v",
    "/mnt/wslg:/mnt/wslg"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-iot.vscode-ros",
        "ms-python.python",
        "redhat.vscode-xml",
        "smilerobotics.urdf",
        "twxs.cmake",
        "eamodio.gitlens",
        "ms-vscode.cmake-tools",
        "ms-python.vscode-pylance",
        "yzhang.markdown-all-in-one"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "ros.distro": "humble",
        "editor.formatOnSave": true,
        "python.defaultInterpreterPath": "/usr/bin/python3"
      }
    }
  },
  "postCreateCommand": "bash -lc 'sudo apt-get update && sudo rosdep init 2>/dev/null || true; rosdep update; sudo rosdep install --from-paths /workspace/src /workspace/Robot/src --ignore-src -y'",
  "postStartCommand": "bash -lc 'source /opt/ros/humble/setup.bash; [ -f /workspace/install/setup.bash ] && source /workspace/install/setup.bash || true; [ -f /workspace/Robot/install/setup.bash ] && source /workspace/Robot/install/setup.bash || true'",
  "shutdownAction": "stopContainer"
}
