{
  "name": "6-DOF Robot Arm (Production)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "USERNAME": "devuser",
      "USER_UID": "1000",
      "USER_GID": "1000"
    }
  },
  "remoteUser": "devuser",
  "workspaceFolder": "/workspace/Robot",
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace/Robot,type=bind,consistency=cached",
    "source=robot-bashhistory,target=/home/devuser/commandhistory,type=volume",
    "source=robot-build-v2,target=/workspace/Robot/build,type=volume",
    "source=robot-install-v2,target=/workspace/Robot/install,type=volume",
    "source=robot-log-v2,target=/workspace/Robot/log,type=volume"
  ],
  "containerEnv": {
    "ROS_DISTRO": "humble",
    "ROS_WS": "/workspace/Robot",
    "PROMPT_COMMAND": "history -a",
    "HISTFILE": "/home/devuser/commandhistory/.bash_history"
  },
  "runArgs": [
    "--network=host",
    "--ipc=host",
    "--privileged",
    "--pid=host",
    "--device=/dev/dri:/dev/dri",
    "--device=/dev/bus/usb:/dev/bus/usb",
    "-e",
    "DISPLAY=${localEnv:DISPLAY}",
    "-e",
    "WAYLAND_DISPLAY=${localEnv:WAYLAND_DISPLAY}",
    "-e",
    "XDG_RUNTIME_DIR=${localEnv:XDG_RUNTIME_DIR}",
    "-e",
    "PULSE_SERVER=${localEnv:PULSE_SERVER}",
    "-v",
    "/tmp/.X11-unix:/tmp/.X11-unix",
    "-v",
    "/mnt/wslg:/mnt/wslg"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "christian-kohler.path-intellisense",
        "dbaeumer.vscode-eslint",
        "donjayamanne.githistory",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "formulahendry.auto-rename-tag",
        "github.codespaces",
        "github.copilot-chat",
        "github.remotehub",
        "google.geminicodeassist",
        "johnpapa.vscode-peacock",
        "mathworks.language-matlab",
        "mhutchie.git-graph",
        "ms-azuretools.vscode-azurecontainerapps",
        "ms-azuretools.vscode-azureresourcegroups",
        "ms-azuretools.vscode-containers",
        "ms-azuretools.vscode-docker",
        "ms-python.debugpy",
        "ms-python.pylint",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.vscode-python-envs",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.vscode-jupyter-slideshow",
        "ms-vscode-remote.remote-containers",
        "ms-vscode-remote.remote-ssh",
        "ms-vscode-remote.remote-ssh-edit",
        "ms-vscode-remote.remote-wsl",
        "ms-vscode-remote.vscode-remote-extensionpack",
        "ms-vscode.azure-repos",
        "ms-vscode.cmake-tools",
        "ms-vscode.cpp-devtools",
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cpptools-themes",
        "ms-vscode.remote-explorer",
        "ms-vscode.remote-repositories",
        "ms-vscode.remote-server",
        "ms-vsliveshare.vsliveshare",
        "ms-iot.vscode-ros",
        "openai.chatgpt",
        "pkief.material-icon-theme",
        "platformio.platformio-ide",
        "ranch-hand-robotics.rde-pack",
        "ranch-hand-robotics.rde-ros-2",
        "ranch-hand-robotics.urdf-editor",
        "smilerobotics.urdf",
        "ritwickdey.liveserver",
        "shd101wyy.markdown-preview-enhanced",
        "streetsidesoftware.code-spell-checker",
        "vadimcn.vscode-lldb",
        "yzhang.markdown-all-in-one",
        "redhat.vscode-xml",
        "yzane.markdown-pdf"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "ros.distro": "humble",
        "editor.formatOnSave": true,
        "python.defaultInterpreterPath": "/usr/bin/python3"
      }
    }
  },
  "postCreateCommand": "bash -lc 'sudo apt-get update && sudo rosdep init 2>/dev/null || true; rosdep update; sudo rosdep install --from-paths /workspace/Robot/src --ignore-src -y || true'",
  "postStartCommand": "bash -lc 'source /opt/ros/humble/setup.bash; [ -f /workspace/Robot/install/setup.bash ] && source /workspace/Robot/install/setup.bash || true'",
  "shutdownAction": "stopContainer"
}
